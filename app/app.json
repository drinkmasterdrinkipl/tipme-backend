{
  "expo": {
    "name": "Tip For Me",
    "slug": "tipme",
    "scheme": "tipforme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0a13"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.drinki.tipme",
      "buildNumber": "5",
      "minimumOsVersion": "18.0",
      "infoPlist": {
        "NFCReaderUsageDescription": "Tip For Me używa NFC do przyjmowania płatności zbliżeniowych.",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-peripheral"
        ],
        "UIRequiredDeviceCapabilities": ["nfc"]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      ["@stripe/stripe-terminal-react-native", {
        "bluetoothBackgroundMode": true,
        "locationWhenInUsePermission": "Tip For Me potrzebuje lokalizacji do przetwarzania płatności Tap to Pay.",
        "bluetoothPeripheralPermission": "Tip For Me używa Bluetooth do połączenia z czytnikiem kart.",
        "bluetoothAlwaysUsagePermission": "Tip For Me używa Bluetooth do połączenia z czytnikiem kart."
      }],
      "./plugins/remove-aps-environment.js"
    ],
    "extra": {
      "eas": {
        "projectId": "ac00f3ac-03e3-4ff5-856e-67134992d9a3"
      }
    }
  }
}
