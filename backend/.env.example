# ============================================
# TipMe — Zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij
# ============================================

# Stripe — klucze API
# Znajdziesz je na: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Webhook Secret (opcjonalnie)
# Ustawisz go po skonfigurowaniu webhooków
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# URL aplikacji (zmień na produkcyjny)
APP_URL=https://tipme-app.example.com

# Port serwera
PORT=3000
